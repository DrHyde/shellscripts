#!/usr/bin/env bash

# This contains a bunch of useful functions for use in scripts. For Reasons,
# it should be pulled into your script not using `source` but thus:
#
#   eval "$(cat $HOME/bin/lib/stdbashlib)"

# define a bunch of functions for colourising text
no_colour='\e[0m'
while read -r function_name colour_code; do
    eval "function ${function_name}_text {
        echo -e '\\e[${colour_code}m'\"\$@\"\$no_colour
    }"
done <<'EOF'
black_on_red     0;30;41
black_on_orange  0;30;48;5;208
black_on_yellow  0;30;43
black_on_green   0;30;42
black_on_blue    0;30;44
black_on_purple  0;30;45
black_on_white   0;30;47
red              1;31
orange           38;5;208
yellow           0;33
green            1;32
blue             1;34
purple           1;35
white            1;37
EOF
unset function_name colour_code

function script_dir {
    (
        cd -- "$(dirname -- "${BASH_SOURCE[0]}")" > /dev/null 2>&1
        pwd
    )
}

function start_timer {
    timer_start_time=$(date +%s)
}

function end_timer {
    timer_elapsed_seconds=$(( $(date +%s) - timer_start_time ))
    unset timer_start_time
}

function timer_elapsed_seconds {
    echo $timer_elapsed_seconds
    unset timer_elapsed_seconds
}

STDLIB_ORIG_PATH="$PATH"

function remove_from_path {
    local dir=$1
    PATH=:$PATH:
    PATH=${PATH//:$dir:/:}
    PATH=${PATH#:}
    export PATH=${PATH%:}
}

function restore_original_path {
    export PATH="$STDLIB_ORIG_PATH"
}
